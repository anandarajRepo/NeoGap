# ─── Kotak Neo Credentials ───────────────────────────────────────────────────
NEO_CONSUMER_KEY=your_consumer_key_here
NEO_CONSUMER_SECRET=your_consumer_secret_here
NEO_ACCESS_TOKEN=
NEO_ENVIRONMENT=prod          # prod | uat

# Optional: pre-fill for non-interactive login (not recommended in production)
NEO_MOBILE=
NEO_PASSWORD=

# ─── Portfolio & Risk ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE=50000
RISK_PER_TRADE=0.30           # 30% of portfolio per trade
MAX_POSITIONS=3
MAX_DAILY_LOSS_PCT=0.02       # Stop new entries if daily loss >= 2%
STOP_LOSS_PCT=0.005           # 0.5% stop-loss from entry
TARGET_MULTIPLIER=2.0         # Target = 2x risk (risk-reward 1:2)
TRAILING_STOP_PCT=0.003       # Trailing stop tightens to 0.3% behind peak
PARTIAL_EXIT_PCT=0.50         # Exit 50% of position at Target 1

# ─── Gap Detection ────────────────────────────────────────────────────────────
MIN_GAP_PCT=0.5               # Minimum gap % to qualify (0.5%)
MAX_GAP_PCT=8.0               # Ignore runaway gaps above 8%
GAP_LOOKBACK_DAYS=20          # Historical days for trend analysis
MIN_GAP_OCCURRENCES=5         # Min historical gaps needed to trust trend
GAP_CONTINUATION_THRESHOLD=0.60   # Trade WITH gap if continuation rate >= 60%
GAP_REVERSAL_THRESHOLD=0.60       # Trade AGAINST gap if reversal rate >= 60%
GAP_CONFIRMATION_MINUTES=5    # Wait N min after open before entering

# ─── Filters ─────────────────────────────────────────────────────────────────
ENABLE_TREND_FILTER=true
ENABLE_VOLUME_FILTER=true
MIN_AVG_VOLUME=100000         # Minimum 20-day avg daily volume

# ─── Operations ───────────────────────────────────────────────────────────────
DRY_RUN=false                 # Set true for paper trading (no real orders)
LOG_LEVEL=INFO
LOG_FILE=logs/gap_strategy.log
POLL_INTERVAL_SECONDS=5
